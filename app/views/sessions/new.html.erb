<div class="flex min-h-full flex-col justify-center px-6 py-12 bg-pulse-mist">

  <!-- Logo et Titre -->
  <div class="sm:mx-auto sm:w-full sm:max-w-sm flex flex-col items-center">
    <h2 class="mt-10 text-center text-3xl font-black leading-9 tracking-tight text-pulse-forest font-alegreya uppercase tracking-[0.2em]">
      Connexion
    </h2>
  </div>

  <div class="mt-10 sm:mx-auto sm:w-full sm:max-w-sm">
    <!-- Notifications Flash (Alert & Notice) -->
    <% if alert = flash[:alert] %>
      <div class="mb-6 rounded-[1.5rem] bg-rose-50 p-4 text-sm font-medium text-rose-500 border border-rose-100 flex items-center gap-3 animate-in fade-in slide-in-from-top-2">
        <span class="text-lg">⚠️</span> <%= alert %>
      </div>
    <% end %>

    <% if notice = flash[:notice] %>
      <div class="mb-6 rounded-[1.5rem] bg-pulse-sage/10 p-4 text-sm font-medium text-pulse-forest border border-pulse-sage/20 flex items-center gap-3 animate-in fade-in slide-in-from-top-2">
        <span class="text-lg">✅</span> <%= notice %>
      </div>
    <% end %>

    <!-- Formulaire de Session -->
    <%= form_with url: session_url, class: "space-y-6" do |form| %>

      <!-- Champ Email -->
      <div>
        <%= form.label :email_address, "Adresse Email",
            class: "block text-[10px] font-bold text-pulse-moss uppercase tracking-widest mb-2 px-1 font-alegreya" %>
        <div class="relative">
          <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "username",
              placeholder: "votre@email.com", value: params[:email_address],
              class: "block w-full rounded-[1.5rem] border-0 py-4 text-pulse-forest shadow-sm ring-1 ring-inset ring-pulse-sage/30 placeholder:text-pulse-sage/60 focus:ring-2 focus:ring-inset focus:ring-pulse-forest bg-white/50 backdrop-blur-sm sm:text-sm sm:leading-6 px-5 transition-all font-palanquin" %>
        </div>
      </div>

      <!-- Champ Mot de passe -->
      <div>
        <div class="flex items-center justify-between px-1">
          <%= form.label :password, "Mot de passe",
              class: "block text-[10px] font-bold text-pulse-moss uppercase tracking-widest mb-2 font-alegreya" %>
          <%= link_to "Oublié ?", new_password_path,
              class: "text-[11px] font-bold text-pulse-forest/60 hover:text-pulse-forest transition-colors font-merriweather italic" %>
        </div>
        <div class="relative">
          <%= form.password_field :password, required: true, autocomplete: "current-password",
              placeholder: "••••••••", maxlength: 72,
              class: "block w-full rounded-[1.5rem] border-0 py-4 text-pulse-forest shadow-sm ring-1 ring-inset ring-pulse-sage/30 placeholder:text-pulse-sage/60 focus:ring-2 focus:ring-inset focus:ring-pulse-forest bg-white/50 backdrop-blur-sm sm:text-sm sm:leading-6 px-5 transition-all font-palanquin" %>
        </div>
      </div>

      <!-- Bouton Submit -->
      <div class="pt-2">
        <%= form.submit "Se connecter",
            class: "flex w-full justify-center rounded-full bg-pulse-forest px-3 py-4 text-sm font-black leading-6 text-white shadow-lg shadow-pulse-forest/20 hover:shadow-xl hover:scale-[1.02] active:scale-95 transition-all cursor-pointer font-alegreya uppercase tracking-widest" %>
      </div>
    <% end %>

    <!-- Lien d'inscription (Optionnel) -->
    <p class="mt-10 text-center text-sm text-pulse-moss font-palanquin">
      Pas encore membre ?
      <%= link_to "Créer un compte", new_registration_path, class: "font-bold text-pulse-forest hover:underline decoration-2 underline-offset-4" %>
    </p>
  </div>
</div>
