<div class="relative flex min-h-0 flex-1 flex-col overflow-hidden bg-pulse-mist font-palanquin">

  <!-- HEADER : Application name & Login button -->
  <header class="flex shrink-0 items-center justify-between px-6 pb-4 pt-[max(1.25rem,env(safe-area-inset-top))]">
    <div class="flex flex-col">
      <span class="subtitle text-pulse-forest text-[9px] font-bold uppercase tracking-[0.2em] font-merriweather">Monitoring</span>
      <h1 class="text-3xl font-black text-pulse-forest tracking-tight font-alegreya">Green Pulse</h1>
    </div>
    <button class="px-5 py-2 bg-pulse-forest text-white text-xs font-bold rounded-full shadow-lg shadow-pulse-forest/20 hover:scale-105 transition-transform font-palanquin">
      Connexion
    </button>
  </header>

  <!-- Scrollable area -->
  <main class="min-h-0 flex-1 overflow-y-auto px-6 pb-36 no-scrollbar font-palanquin">

    <!-- Hero section -->
    <section class="mb-8 mt-2">
      <div class="bg-white/60 backdrop-blur-sm p-6 rounded-[2.5rem] border border-white/50 shadow-sm relative overflow-hidden font-palanquin">
        <div class="relative z-10">
          <h2 class="text-2xl font-black text-pulse-forest leading-tight mb-2 font-alegreya">Prenez le pouls <br>de votre jardin.</h2>
          <p class="subtitle text-xs text-pulse-moss italic max-w-[180px] font-merriweather">Vérifiez l'humidité du sol en temps réel.</p>
        </div>
        <div class="absolute -right-4 -bottom-4 text-8xl opacity-20">🌿</div>
      </div>
    </section>

    <!-- Global stats -->
    <section class="grid grid-cols-3 gap-3 mb-8 font-palanquin">
      <div class="bg-white p-4 rounded-[2rem] shadow-sm border border-white/50 text-center">
        <div class="w-8 h-8 bg-pulse-mist rounded-full flex items-center justify-center mx-auto mb-2">
          <svg class="w-4 h-4 text-pulse-forest" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707m12.728 0l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707-.707M6.343 6.343l-.707-.707"></path>
          </svg>
        </div>
        <p class="text-[9px] font-bold text-gray-400 uppercase tracking-widest font-merriweather">Air</p>
        <p class="text-xl font-black text-pulse-forest font-alegreya">24°</p>
      </div>
      <div class="bg-white p-4 rounded-[2rem] shadow-sm border border-white/50 text-center">
        <div class="w-8 h-8 bg-pulse-sage/20 rounded-full flex items-center justify-center mx-auto mb-2 text-pulse-forest">💧</div>
        <p class="text-[9px] font-bold text-gray-400 uppercase tracking-widest font-merriweather">Sol</p>
        <p class="text-xl font-black text-pulse-forest font-alegreya">68%</p>
      </div>
      <div class="bg-white p-4 rounded-[2rem] shadow-sm border border-white/50 text-center">
        <div class="w-8 h-8 bg-pulse-moss/10 rounded-full flex items-center justify-center mx-auto mb-2">⚡</div>
        <p class="text-[9px] font-bold text-gray-400 uppercase tracking-widest font-merriweather">Batterie</p>
        <p class="text-xl font-black text-pulse-forest font-alegreya">92%</p>
      </div>
    </section>

    <!-- Humidity alert -->
    <section class="mb-8 font-palanquin">
      <div class="bg-pulse-forest p-5 rounded-[2.5rem] flex items-center gap-4 shadow-xl shadow-pulse-forest/10">
        <div class="w-12 h-12 bg-white/10 rounded-2xl flex items-center justify-center text-2xl">⚠️</div>
        <div class="flex-1">
          <p class="subtitle text-[10px] font-bold text-pulse-sage uppercase tracking-wider font-merriweather">Alerte Sécheresse</p>
          <p class="text-base font-bold text-white font-palanquin">Le Ficus a besoin d'eau</p>
        </div>
        <div class="text-right">
          <span class="text-2xl font-black text-white font-alegreya">12%</span>
        </div>
      </div>
    </section>

    <!-- Plants list -->
    <section class="mb-8 font-palanquin">
      <div class="flex justify-between items-center mb-5 px-2">
        <h3 class="text-xl font-black text-pulse-forest font-alegreya">Mes Capteurs</h3>
        <button class="subtitle text-[9px] font-black text-pulse-moss uppercase tracking-widest font-merriweather">Voir tout</button>
      </div>

      <div class="space-y-4">
        <!-- Plant 1 -->
        <div class="bg-white p-4 rounded-[2.2rem] shadow-sm border border-white/50 flex items-center gap-4 group font-palanquin">
          <div class="w-16 h-16 bg-pulse-mist rounded-3xl flex items-center justify-center text-3xl group-hover:scale-110 transition-transform duration-300">🌵</div>
          <div class="flex-1">
            <h4 class="text-lg font-bold text-pulse-forest leading-tight font-alegreya">Cactus Mexicain</h4>
            <p class="text-[10px] text-gray-400 font-medium font-merriweather">Salon • Dernière synchro 2m</p>
            <!-- Humidity bar -->
            <div class="mt-2 w-full h-1.5 bg-pulse-mist rounded-full overflow-hidden">
              <div class="h-full bg-pulse-moss w-[80%] rounded-full"></div>
            </div>
          </div>
          <div class="text-right">
            <span class="text-base font-black text-pulse-forest font-alegreya">80%</span>
          </div>
        </div>

        <!-- Plant 2 -->
        <div class="bg-white p-4 rounded-[2.2rem] shadow-sm border border-white/50 flex items-center gap-4 group font-palanquin">
          <div class="w-16 h-16 bg-pulse-mist rounded-3xl flex items-center justify-center text-3xl group-hover:scale-110 transition-transform duration-300">🪴</div>
          <div class="flex-1">
            <h4 class="text-lg font-bold text-pulse-forest leading-tight font-alegreya">Monstera Deliciosa</h4>
            <p class="text-[10px] text-gray-400 font-medium font-merriweather">Bureau • Dernière synchro 15m</p>
            <!-- Humidity bar -->
            <div class="mt-2 w-full h-1.5 bg-pulse-mist rounded-full overflow-hidden">
              <div class="h-full bg-pulse-sage w-[45%] rounded-full"></div>
            </div>
          </div>
          <div class="text-right">
            <span class="text-base font-black text-pulse-forest font-alegreya">45%</span>
          </div>
        </div>
      </div>
    </section>
  </main>

  <!-- Bottom navigation -->
  <nav class="absolute bottom-[max(1.5rem,env(safe-area-inset-bottom))] left-6 right-6 z-40 flex h-20 items-center justify-around rounded-[2.5rem] border border-white/50 bg-white/90 px-4 shadow-xl backdrop-blur-md font-palanquin">
    <button class="text-pulse-forest flex flex-col items-center gap-1 font-palanquin">
      <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20">
        <path d="M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L4 10.414V17a1 1 0 001 1h2a1 1 0 001-1v-2a1 1 0 011-1h2a1 1 0 011 1v2a1 1 0 001 1h2a1 1 0 001-1v-6.586l.293.293a1 1 0 001.414-1.414l-7-7z"></path>
      </svg>
    </button>

    <button class="w-12 h-12 bg-pulse-forest rounded-2xl flex items-center justify-center text-white shadow-lg shadow-pulse-forest/30 -translate-y-2 rotate-45 font-alegreya">
      <svg class="w-6 h-6 -rotate-45" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
      </svg>
    </button>

    <button class="text-gray-300 flex flex-col items-center gap-1 font-palanquin">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 8v8m-4-5v5m-4-2v2m-2 4h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
      </svg>
    </button>
  </nav>

  <!-- Home indicator -->
  <div class="pointer-events-none absolute bottom-1 left-1/2 h-1.5 w-32 -translate-x-1/2 rounded-full bg-pulse-forest/10"></div>
</div>
