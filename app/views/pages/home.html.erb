<div class="relative flex min-h-0 flex-1 flex-col overflow-hidden bg-pulse-mist font-palanquin">
  <% unless authenticated? %>
    <!-- HEADER : Application name & Login button -->
    <header class="flex shrink-0 items-center justify-between px-6 pb-4 pt-[max(1.25rem,env(safe-area-inset-top))]">
      <div class="flex flex-col">
        <h1 class="text-3xl font-black text-pulse-forest tracking-tight font-alegreya">Green Pulse</h1>
      </div>

      <%= button_to t('.sign_in'), new_session_path, method: :get, class: "px-5 py-2 bg-pulse-forest text-white text-xs font-bold rounded-full shadow-lg shadow-pulse-forest/20 font-palanquin" %>
    </header>
  <% end %>

  <!-- Scrollable area -->
  <main class="min-h-0 flex-1 overflow-y-auto px-6 <%= authenticated? ? 'pt-6 pb-5' : 'pb-2' %> no-scrollbar font-palanquin">

    <!-- Hero section -->
    <section class="mb-8 mt-2">
      <div class="bg-white/60 backdrop-blur-sm p-6 rounded-[2.5rem] border border-white/50 shadow-sm relative overflow-hidden font-palanquin">
        <div class="relative z-10">
          <h2 class="text-2xl font-black text-pulse-forest leading-tight mb-2 font-alegreya"><%= t('.hero_title_html') %></h2>
          <p class="subtitle text-xs text-pulse-moss italic max-w-[180px] font-merriweather"><%= t('.hero_subtitle') %></p>
        </div>
        <div class="absolute -right-4 -bottom-4 text-8xl opacity-20">🌿</div>
      </div>
    </section>

    <!-- Global stats -->
    <section class="grid grid-cols-3 gap-3 mb-8 font-palanquin">
      <div class="bg-white p-4 rounded-[2rem] shadow-sm border border-white/50 text-center">
        <div class="w-8 h-8 bg-pulse-mist rounded-full flex items-center justify-center mx-auto mb-2">
          <svg class="w-4 h-4 text-pulse-forest" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707m12.728 0l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707-.707M6.343 6.343l-.707-.707"></path>
          </svg>
        </div>
        <p class="text-[9px] font-bold text-gray-400 uppercase tracking-widest font-merriweather"><%= t('.stat_air') %></p>
        <p class="text-xl font-black text-pulse-forest font-alegreya">24°</p>
      </div>
      <div class="bg-white p-4 rounded-[2rem] shadow-sm border border-white/50 text-center">
        <div class="w-8 h-8 bg-pulse-sage/20 rounded-full flex items-center justify-center mx-auto mb-2 text-pulse-forest">💧</div>
        <p class="text-[9px] font-bold text-gray-400 uppercase tracking-widest font-merriweather"><%= t('.stat_soil') %></p>
        <p class="text-xl font-black text-pulse-forest font-alegreya">68%</p>
      </div>
      <div class="bg-white p-4 rounded-[2rem] shadow-sm border border-white/50 text-center">
        <div class="w-8 h-8 bg-pulse-moss/10 rounded-full flex items-center justify-center mx-auto mb-2">⚡</div>
        <p class="text-[9px] font-bold text-gray-400 uppercase tracking-widest font-merriweather"><%= t('.stat_battery') %></p>
        <p class="text-xl font-black text-pulse-forest font-alegreya">92%</p>
      </div>
    </section>

    <!-- Humidity alert -->
    <section class="mb-8 font-palanquin">
      <div class="bg-pulse-forest p-5 rounded-[2.5rem] flex items-center gap-4 shadow-xl shadow-pulse-forest/10">
        <div class="w-12 h-12 bg-white/10 rounded-2xl flex items-center justify-center text-2xl">⚠️</div>
        <div class="flex-1">
          <p class="subtitle text-[10px] font-bold text-pulse-sage uppercase tracking-wider font-merriweather"><%= t('.alert_title') %></p>
          <p class="text-base font-bold text-white font-palanquin"><%= t('.alert_body') %></p>
        </div>
        <div class="text-right">
          <span class="text-2xl font-black text-white font-alegreya">12%</span>
        </div>
      </div>
    </section>

    <!-- Plants list -->
    <section class="mb-8 font-palanquin">
      <div class="flex justify-between items-center mb-5 px-2">
        <h3 class="text-xl font-black text-pulse-forest font-alegreya"><%= t('.sensors_heading') %></h3>
        <button class="subtitle text-[9px] font-black text-pulse-moss uppercase tracking-widest font-merriweather"><%= t('.see_all') %></button>
      </div>

      <div class="space-y-4">
        <!-- Plant 1 -->
        <div class="bg-white p-4 rounded-[2.2rem] shadow-sm border border-white/50 flex items-center gap-4 group font-palanquin">
          <div class="w-16 h-16 bg-pulse-mist rounded-3xl flex items-center justify-center text-3xl group-hover:scale-110 transition-transform duration-300">🌵</div>
          <div class="flex-1">
            <h4 class="text-lg font-bold text-pulse-forest leading-tight font-alegreya"><%= t('.demo_plant_cactus') %></h4>
            <p class="text-[10px] text-gray-400 font-medium font-merriweather"><%= t('.demo_meta_salon') %></p>
            <!-- Humidity bar -->
            <div class="mt-2 w-full h-1.5 bg-pulse-mist rounded-full overflow-hidden">
              <div class="h-full bg-pulse-moss w-[80%] rounded-full"></div>
            </div>
          </div>
          <div class="text-right">
            <span class="text-base font-black text-pulse-forest font-alegreya">80%</span>
          </div>
        </div>

        <!-- Plant 2 -->
        <div class="bg-white p-4 rounded-[2.2rem] shadow-sm border border-white/50 flex items-center gap-4 group font-palanquin">
          <div class="w-16 h-16 bg-pulse-mist rounded-3xl flex items-center justify-center text-3xl group-hover:scale-110 transition-transform duration-300">🪴</div>
          <div class="flex-1">
            <h4 class="text-lg font-bold text-pulse-forest leading-tight font-alegreya"><%= t('.demo_plant_monstera') %></h4>
            <p class="text-[10px] text-gray-400 font-medium font-merriweather"><%= t('.demo_meta_bureau') %></p>
            <!-- Humidity bar -->
            <div class="mt-2 w-full h-1.5 bg-pulse-mist rounded-full overflow-hidden">
              <div class="h-full bg-pulse-sage w-[45%] rounded-full"></div>
            </div>
          </div>
          <div class="text-right">
            <span class="text-base font-black text-pulse-forest font-alegreya">45%</span>
          </div>
        </div>
      </div>
    </section>
  </main>

  <% if authenticated? %>
    <%= render Components::NavigationBar.new %>
  <% end %>
</div>
