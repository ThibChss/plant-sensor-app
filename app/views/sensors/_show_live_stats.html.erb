<div class="mt-8 grid grid-cols-2 gap-4" id="show_stats_<%= sensor.dom_id %>">
  <div class="bg-pulse-mist/40 rounded-[2rem] p-6 text-center border border-white/50 flex flex-col items-center">
    <div class="min-h-[24px] flex items-center justify-center mb-2">
      <p class="text-[9px] font-bold text-pulse-moss uppercase tracking-[0.15em] opacity-50 font-palanquin leading-tight"><%= t('.soil_moisture_label') %></p>
    </div>
    <div class="flex items-baseline gap-0.5">
      <span class="text-3xl font-black text-pulse-forest font-alegreya leading-none">
        <%= sensor.moisture_level_percent || "--" %>
      </span>
      <span class="text-sm font-bold text-pulse-forest/30 font-alegreya translate-y-[-1px]">%</span>
    </div>
  </div>

  <div class="bg-pulse-mist/40 rounded-[2rem] p-6 text-center border border-white/50 flex flex-col items-center">
    <div class="min-h-[24px] flex items-center justify-center mb-2">
      <p class="text-[9px] font-bold text-pulse-moss uppercase tracking-[0.15em] opacity-50 font-palanquin leading-tight"><%= t('.battery_label') %></p>
    </div>
    <div class="flex items-baseline gap-0.5">
      <span class="text-3xl font-black text-pulse-forest font-alegreya leading-none">
        <%= sensor.battery_level_percent || "--" %>
      </span>
      <span class="text-sm font-bold text-pulse-forest/30 font-alegreya translate-y-[-1px]">%</span>
    </div>
  </div>
</div>
