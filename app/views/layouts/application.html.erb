<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
  <head>
    <title><%= content_for(:title) || "Green Pulse" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
    <meta name="theme-color" content="#346739" media="(prefers-color-scheme: light)">
    <meta name="theme-color" content="#346739" media="(prefers-color-scheme: dark)">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-title" content="Green Pulse">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="application-name" content="Green Pulse">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%= tag.link rel: 'manifest', href: pwa_manifest_path(format: :json) %>

    <%= favicon_link_tag '/icon.png', type: 'image/png' %>
    <link rel="icon" href="/icon.png" type="image/png">
    <%= tag.link rel: 'apple-touch-icon', href: '/icon.png' %>

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <%= tag.script src: 'https://cdn.jsdelivr.net/npm/@tailwindplus/elements@1', type: 'module', nonce: content_security_policy_nonce %>
  </head>

  <%= render Components::Layout::Frame.new(browser: @browser) do %>
    <%= render 'shared/flash', browser: @browser %>

    <div class="flex min-h-0 min-w-0 flex-1 flex-col overflow-hidden"
         data-controller="push-notifications <%= 'presence' if Current.user %>"
         data-push-notifications-vapid-public-key-value="<%= Rails.application.credentials.vapid_key.public.delete('=') %>"
         data-push-notifications-enabled-value="<%= Current.user&.push_notifications_enabled? || false %>">
      <%= yield %>
    </div>
  <% end %>
</html>
