<div class="relative flex min-h-0 flex-1 flex-col overflow-hidden bg-pulse-mist">
  <%# Modals must not sit between main and nav — <el-dialog> hosts can grow the flex column on iOS PWA. %>
  <div class="flex min-h-0 min-w-0 flex-1 flex-col overflow-hidden">
    <main class="min-h-0 flex-1 overflow-y-auto no-scrollbar pb-8">
    <div class="flex flex-col items-center pt-12 pb-10 px-6">
      <div class="relative mb-6">
        <div class="w-28 h-28 bg-white rounded-[2.5rem] shadow-xl shadow-pulse-forest/5 flex items-center justify-center border-4 border-white overflow-hidden">
          <% if @current_user&.first_name.present? %>
            <span class="text-4xl font-black text-pulse-forest font-alegreya">
              <%= @current_user.initials %>
            </span>
          <% else %>
            <%= icon "user", class: "w-12 h-12 text-pulse-sage" %>
          <% end %>
        </div>
      </div>

      <h2 class="text-3xl font-black text-pulse-forest font-alegreya tracking-tight">
        <%= @current_user&.full_name %>
      </h2>
      <p class="text-sm text-pulse-moss font-palanquin opacity-70 mb-8">
        <%= @current_user&.email_address %>
      </p>

      <%= link_to "#", class: "px-8 py-3 bg-pulse-forest text-white text-sm font-bold rounded-full shadow-lg shadow-pulse-forest/20 transition-all hover:scale-105 active:scale-95 font-palanquin" do %>
        <%= t('pages.profile.edit_profile') %>
      <% end %>
    </div>

    <div class="px-6 space-y-8">

      <div>
        <h3 class="text-[10px] font-bold text-pulse-moss uppercase tracking-[0.2em] mb-4 px-4 font-merriweather">
          <%= t('pages.profile.preferences_heading') %>
        </h3>
        <div class="bg-white/40 backdrop-blur-xl rounded-[2.5rem] border border-white/40 overflow-hidden shadow-sm">
          <div class="flex items-center justify-between px-5 py-2 hover:bg-white/20 transition-colors">
            <div class="flex items-center gap-4">
              <div class="w-10 h-10 rounded-2xl flex items-center justify-center text-pulse-forest">
                <%= icon "bell", class: "w-5 h-5" %>
              </div>
              <span class="font-bold text-pulse-forest font-palanquin"><%= t('pages.profile.push_notifications') %></span>
            </div>
            <button type="button"
                    data-controller="setting-toggle"
                    data-setting-toggle-url-value="<%= push_notifications_profile_path %>"
                    data-setting-toggle-enabled-value="<%= @current_user.push_notifications_enabled? %>"
                    data-action="click->setting-toggle#toggle"
                    class="relative inline-flex h-7 w-12 shrink-0 cursor-pointer items-center rounded-full transition-colors focus:outline-none"
                    aria-label="<%= t('pages.profile.notifications_switch_aria') %>">
              <span data-setting-toggle-target="knob"
                    class="inline-block h-5 w-5 transform rounded-full bg-white shadow-sm transition-transform"></span>
            </button>
          </div>

          <div class="h-px bg-pulse-forest/5 mx-5"></div>

          <button
            type="button"
            command="show-modal"
            commandfor="language-dialog"
            class="flex w-full items-center justify-between px-5 py-2 text-left transition-colors hover:bg-white/20"
          >
            <div class="flex items-center gap-4">
              <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-2xl text-pulse-forest">
                <%= icon 'languages', class: 'w-5 h-5' %>
              </div>
              <span class="font-bold text-pulse-forest font-palanquin"><%= t('pages.profile.language') %></span>
            </div>
            <div class="flex items-center gap-2">
              <span class="text-xs font-semibold text-pulse-moss/70 font-palanquin"><%= t("pages.profile.language_#{@current_user.locale}") %></span>
              <%= icon 'chevron-right', class: 'w-4 h-4 text-pulse-moss/30' %>
            </div>
          </button>

          <div class="h-px bg-pulse-forest/5 mx-5"></div>

          <%= link_to "#", class: "flex items-center justify-between px-5 py-2 hover:bg-white/20 transition-colors" do %>
            <div class="flex items-center gap-4">
              <div class="w-10 h-10 rounded-2xl flex items-center justify-center text-pulse-forest">
                <%= icon "shield-check", class: "w-5 h-5" %>
              </div>
              <span class="font-bold text-pulse-forest font-palanquin"><%= t('pages.profile.security_pin') %></span>
            </div>
            <%= icon "chevron-right", class: "w-4 h-4 text-pulse-moss/30" %>
          <% end %>
        </div>
      </div>

      <div>
        <h3 class="text-[10px] font-bold text-pulse-moss uppercase tracking-[0.2em] mb-4 px-4 font-merriweather">
          <%= t('pages.profile.account_heading') %>
        </h3>
        <div class="bg-white/40 backdrop-blur-xl rounded-[2.5rem] border border-white/40 overflow-hidden shadow-sm">
          <%= link_to "#", class: "flex items-center justify-between px-5 py-2 hover:bg-white/20 transition-colors" do %>
            <div class="flex items-center gap-4">
              <div class="w-10 h-10 rounded-2xl flex items-center justify-center text-pulse-forest">
                <%= icon "circle-question-mark", class: "w-5 h-5" %>
              </div>
              <span class="font-bold text-pulse-forest font-palanquin"><%= t('pages.profile.help_support') %></span>
            </div>
            <%= icon "chevron-right", class: "w-4 h-4 text-pulse-moss/30" %>
          <% end %>

          <div class="h-px bg-pulse-forest/5 mx-5"></div>

          <button
            type="button"
            command="show-modal"
            commandfor="sign-out-dialog"
            class="flex w-full items-center justify-between px-5 py-2 text-left transition-colors hover:bg-white/20"
          >
            <div class="flex items-center gap-4">
              <div class="w-10 h-10 rounded-2xl flex items-center justify-center text-rose-500">
                <%= icon "log-out", class: "w-5 h-5" %>
              </div>
              <span class="font-bold text-rose-500 font-palanquin"><%= t('pages.profile.sign_out') %></span>
            </div>
            <%= icon "chevron-right", class: "w-4 h-4 text-rose-200" %>
          </button>
        </div>
      </div>
    </div>
    </main>

    <%= render Components::NavigationBar.new %>
  </div>

  <div class="pointer-events-none absolute inset-0 z-40 min-h-0 overflow-x-hidden [&_dialog]:pointer-events-auto [&_el-dialog]:pointer-events-auto">
    <%= render 'language_modal', user: @current_user %>
    <%= render 'sign_out_modal' %>
  </div>
</div>
