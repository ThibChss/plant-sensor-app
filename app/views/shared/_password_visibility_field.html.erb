<%# locals: (form:, field:, options:, toggle_class: nil) %>
<%
  opts = (local_assigns[:options] || {}).dup
  opts[:data] = { password_visibility_target: "input" }.merge(opts[:data] || {})
  existing_class = opts[:class].to_s
  opts[:class] = "#{existing_class} pr-12".strip
  toggle_btn_class = toggle_class.presence || "absolute inset-y-0 right-0 flex w-11 shrink-0 items-center justify-center pr-2 text-pulse-moss hover:text-pulse-forest transition-colors"
%>

<div class="relative" data-controller="password-visibility">
  <%= form.password_field field, **opts %>

  <button
    type="button"
    class="<%= toggle_btn_class %>"
    data-password-visibility-target="visibilityButton"
    data-action="password-visibility#toggle"
    aria-label="Afficher le mot de passe"
    aria-pressed="false"
  >
    <span data-password-visibility-target="showIcon">
      <%= icon "eye", class: "w-5 h-5" %>
    </span>

    <span data-password-visibility-target="hideIcon" class="hidden">
      <%= icon "eye-off", class: "w-5 h-5" %>
    </span>
  </button>
</div>
