<div class="relative flex min-h-0 w-full flex-1 flex-col overflow-hidden bg-pulse-mist">

  <%= turbo_stream_from Current.user, @sensor.dom_id %>

  <% cache [@sensor, @plant, I18n.locale] do %>
    <!-- Zone de contenu défilante (Correction du Scroll) -->
    <main class="min-h-0 flex-1 overflow-y-auto no-scrollbar">

      <!-- Header avec Image & Glassmorphism -->
      <div class="relative h-80 w-full overflow-hidden shrink-0">
        <%= image_tag @plant.image_url, class: "w-full h-full object-cover transition-transform duration-1000" %>

        <!-- Gradients d'ombre -->
        <div class="absolute inset-0 bg-gradient-to-b from-black/30 via-transparent to-transparent"></div>
        <div class="absolute inset-0 bg-gradient-to-t from-pulse-mist via-transparent to-transparent"></div>

        <!-- Bouton Retour -->
        <%= link_to sensors_path, class: "absolute top-14 left-6 z-10 w-10 h-10 bg-white/20 backdrop-blur-md rounded-2xl flex items-center justify-center text-white border border-white/20 active:scale-90 transition-all" do %>
          <%= icon "chevron-left", class: "w-5 h-5" %>
        <% end %>

        <!-- Badge Localisation -->
        <div class="absolute top-14 right-6 z-10 px-4 py-2 bg-white/20 backdrop-blur-md rounded-full border border-white/20 flex items-center py-3">
          <span class="text-[10px] font-black text-white uppercase tracking-widest">
            <%= t("sensor.location.#{@sensor.location}") %>
          </span>
        </div>
      </div>

      <!-- Contenu Principal -->
      <div class="-mt-14 relative px-6 space-y-6 pb-10">

        <!-- Carte d'Identité -->
        <div class="bg-white rounded-[2.5rem] p-8 shadow-xl shadow-pulse-forest/5 relative border border-white">
          <div class="text-center space-y-1">
            <h1 class="text-3xl font-black text-pulse-forest font-alegreya leading-tight">
              <%= @sensor.nickname %>
            </h1>
            <p class="text-xs font-bold text-pulse-moss italic opacity-40 font-merriweather">
              <%= @plant.display_name %>
            </p>
          </div>

          <!-- Stats Temps Réel (Fix Alignement des Titres et Chiffres) -->
          <%= render 'show_live_stats', sensor: @sensor %>
        </div>

        <!-- Fiche Technique Botanique (Fix Alignement Icônes/Texte et Symboles) -->
        <div class="space-y-4">
          <h3 class="text-[10px] font-bold text-pulse-moss uppercase tracking-[0.2em] px-4 opacity-50 font-merriweather">
            <%= t('.ideal_needs_heading') %>
          </h3>

          <div class="grid grid-cols-2 gap-4">
            <!-- Light -->
            <%= render Components::PlantInfo.new(icon: "sun", size_label: t('.light_label'), color: "orange") do %>
              <span><%= @plant.light %></span>
              <span class="mx-0.5 text-pulse-forest/30 translate-y-[-0.5px]">/</span>
              <span><%= t('.scale_max') %></span>
            <% end %>

            <!-- pH -->
            <%= render Components::PlantInfo.new(icon: "beaker", size_label: t('.soil_ph_label'), color: "purple") do %>
              <span><%= sprintf('%.1f', @plant.ph_minimum) %></span>
              <span class="mx-1 text-pulse-forest/30 translate-y-[-1px] font-palanquin">~</span>
              <span><%= sprintf('%.1f', @plant.ph_maximum) %></span>
            <% end %>

            <!-- Atmospheric humidity -->
            <%= render Components::PlantInfo.new(icon: "wind", size_label: t('.air_label'), color: "emerald") do %>
              <span><%= @plant.atmospheric_humidity %></span>
              <span class="mx-0.5 text-pulse-forest/30 translate-y-[-0.5px]">/</span>
              <span><%= t('.scale_max') %></span>
            <% end %>

            <!-- Row spacing -->
            <%= render Components::PlantInfo.new(icon: "arrow-left-right", size_label: t('.size_label'), color: "yellow") do %>
              <span><%= @plant.spread['cm'] %></span>
              <span class="ml-1 text-[10px] font-bold opacity-30"><%= t('.cm_unit') %></span>
            <% end %>

            <!-- Watering frequency -->
            <%= render Components::PlantInfo.new(icon: "droplets", size_label: t('.watering_frequency_label'), color: "blue") do %>
              <% if @plant.watering_frequency[@sensor.environment].values.all?(&:present?) %>
                <span><%= @plant.watering_frequency[@sensor.environment]['min_days'] %></span>
                <span class="mx-1 text-pulse-forest/30 translate-y-[-1px]">~</span>
                <span><%= @plant.watering_frequency[@sensor.environment]['max_days'] %></span>
                <span class="ml-1 text-[8px] font-bold opacity-30 uppercase tracking-tighter"><%= t('.days_unit') %></span>
              <% elsif @plant.watering_frequency[@sensor.environment]['min_days'].present? %>
                <span class="mx-1 text-pulse-forest/30 translate-y-[-1px]">~</span>
                <span><%= @plant.watering_frequency[@sensor.environment]['min_days'] %></span>
                <span class="ml-1 text-[8px] font-bold opacity-30 uppercase tracking-tighter"><%= t('.days_unit') %></span>
              <% elsif @plant.watering_frequency[@sensor.environment]['max_days'].present? %>
                <span class="mx-1 text-pulse-forest/30 translate-y-[-1px]">~</span>
                <span><%= @plant.watering_frequency[@sensor.environment]['max_days'] %></span>
                <span class="ml-1 text-[8px] font-bold opacity-30 uppercase tracking-tighter"><%= t('.days_unit') %></span>
              <% else %>
                <span>--</span>
              <% end %>
            <% end %>
          </div>
        </div>

        <div class="bg-white/60 backdrop-blur-sm rounded-[2.5rem] p-8 border border-white shadow-sm">
          <h3 class="text-[10px] font-bold text-pulse-moss uppercase tracking-[0.2em] mb-6 text-center opacity-40 font-merriweather">
            <%= t('.growth_period_heading') %>
          </h3>
          <div class="flex justify-between items-end h-8 gap-1.5 px-1">
            <% Plant::MONTHS.each do |month| %>
              <div class="flex-1 flex flex-col items-center gap-2">
                <div class="w-full rounded-full transition-all duration-700 <%= @plant.growth_period?(month) ? 'h-6 bg-pulse-forest shadow-sm' : 'h-2 bg-pulse-moss/10' %>"></div>
                <span class="text-[7px] font-bold text-pulse-moss uppercase tracking-tighter <%= 'text-pulse-forest' if @plant.growth_period?(month) %>">
                  <%= month[0].upcase %>
                </span>
              </div>
            <% end %>
          </div>
        </div>

        <div class="bg-pulse-forest rounded-[2.5rem] p-8 text-white shadow-xl shadow-pulse-forest/20 relative overflow-hidden mb-4">
          <div class="relative z-10">
            <div class="flex items-center gap-3 mb-4">
              <span class="text-xl">✨</span>
              <h3 class="text-[10px] font-bold uppercase tracking-[0.2em] text-pulse-light">
                <%= t('.botanist_analysis_heading') %>
              </h3>
            </div>
            <p class="text-sm leading-relaxed font-merriweather italic opacity-90">
              <%= t(
                '.botanist_analysis',
                plant_name: @plant.display_name,
                moisture: @plant.min_soil_moisture[@sensor.environment],
                location: t("sensor.location.#{@sensor.location}").downcase
              ) %>
            </p>
          </div>
          <div class="absolute -right-8 -bottom-8 text-9xl opacity-20 rotate-12">🌿</div>
        </div>

        <div class="pt-4 flex flex-col items-center gap-2">
          <p class="text-[9px] text-pulse-moss/30 font-bold uppercase tracking-widest">
            ID: <%= @sensor.uid %>
          </p>

          <%= button_to @sensor, method: :delete,
              form: { data: { turbo_confirm: t('.delete_confirm') } },
              class: "text-[10px] font-bold text-rose-500/40 uppercase tracking-widest hover:text-rose-500 transition-colors py-4 px-8" do %>
            <%= t('.unlink_sensor') %>
          <% end %>
        </div>
      </div>
    </main>
  <% end %>

  <%= render Components::NavigationBar.new %>
</div>
