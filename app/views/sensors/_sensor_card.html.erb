<%
  # On ne calcule la "soif" que si on a une donnée
  has_data = sensor.moisture_level_percent.present?
  is_thirsty = has_data && sensor.thirsty?

  # Fond de carte : standard par défaut, rosé uniquement si soif confirmée
  container_classes = is_thirsty ? 'bg-rose-50/80 border-rose-200/60 shadow-sm' : 'bg-white border-white/50 shadow-sm'

  plant = sensor.plant
  light_level = plant.growth_data&.dig('light')
%>

<div id="sensor_<%= sensor.id %>"
     class="<%= container_classes %> block w-full overflow-hidden rounded-[2.5rem] border transition-all duration-700 group [&:not(:last-child)]:mb-6">

  <!-- Section Image (Haut de la carte) -->
  <div class="relative h-40 w-full overflow-hidden bg-pulse-mist">
    <%= image_tag plant.image_url,
        class: "h-full w-full object-cover transition-transform duration-1000 group-hover:scale-110 #{'opacity-50 grayscale-[20%]' unless has_data}",
        alt: sensor.nickname %>

    <!-- Overlay dégradé -->
    <div class="absolute inset-0 bg-gradient-to-t from-black/50 via-transparent to-transparent"></div>

    <!-- Badges Glassmorphism -->
    <div class="absolute top-4 left-4 flex gap-2">
      <% if is_thirsty %>
        <span class="inline-flex items-center gap-1 rounded-full bg-rose-500/40 px-3 py-1.5 text-[10px] font-black uppercase tracking-widest text-white shadow-lg shadow-rose-500/5 backdrop-blur-md border border-white/20">
          <span class="animate-pulse">💧</span> SOIF
        </span>
      <% elsif !has_data %>
        <span class="inline-flex items-center gap-1 rounded-full bg-pulse-forest/20 px-3 py-1.5 text-[10px] font-black uppercase tracking-widest text-white backdrop-blur-md border border-white/10">
          OFFLINE
        </span>
      <% end %>

      <span class="rounded-full bg-white/20 px-3 py-1.5 text-[10px] font-bold uppercase tracking-widest text-white backdrop-blur-md border border-white/20">
        <%= t("sensor.location.#{sensor.location}") %>
      </span>
    </div>

    <!-- Surnom -->
    <div class="absolute bottom-4 left-6 right-6">
      <h4 class="text-2xl font-black text-white leading-tight drop-shadow-md font-alegreya">
        <%= sensor.nickname %>
      </h4>
    </div>
  </div>

  <!-- Zone Contenu (Bas de la carte) -->
  <div class="p-6 text-center">

    <!-- Ligne de Monitoring -->
    <div class="flex items-center justify-between mb-5 px-1">
      <div class="text-left">
        <p class="text-[9px] font-bold text-pulse-moss uppercase tracking-[0.2em] mb-1 opacity-60 font-palanquin">
          Humidité • <%= t("sensor.environment.#{sensor.environment}") %>
        </p>
        <div class="flex items-baseline gap-1">
          <% if has_data %>
            <span class="text-3xl font-black <%= is_thirsty ? 'text-rose-500/90' : 'text-pulse-forest' %> font-alegreya transition-colors">
              <%= sensor.moisture_level_percent %>%
            </span>
          <% else %>
            <span class="text-xl font-bold text-pulse-moss/30 font-alegreya italic tracking-tight">
              Calcul en cours...
            </span>
          <% end %>
        </div>
      </div>

      <% if light_level.present? %>
        <div class="text-right">
          <p class="text-[9px] font-bold text-pulse-moss uppercase tracking-[0.2em] mb-1 opacity-60 font-palanquin">Lumière</p>
          <div class="flex items-center justify-end gap-1.5">
            <span class="text-lg font-black text-pulse-forest font-alegreya"><%= light_level %>/10</span>
            <%= icon "sun", class: "w-4 h-4 text-pulse-sage" %>
          </div>
        </div>
      <% end %>
    </div>

    <!-- Barre de progression SVG -->
    <div class="relative mb-6">
      <svg class="h-1.5 w-full rounded-full" viewBox="0 0 100 2" preserveAspectRatio="none" aria-hidden="true">
        <%# Rail de la barre %>
        <rect width="100" height="2" rx="1" class="<%= is_thirsty ? 'fill-rose-900/10' : 'fill-pulse-forest/10' %>" />

        <% if has_data %>
          <%# Barre active %>
          <rect width="<%= sensor.moisture_level_percent %>" height="2" rx="1"
                class="<%= is_thirsty ? 'fill-rose-500/80' : 'fill-pulse-forest' %> transition-all duration-1000" />
        <% end %>
      </svg>

      <% if is_thirsty %>
        <p class="text-[9px] font-bold text-rose-500/70 mt-2 uppercase tracking-tighter text-left px-1">
          Seuil critique : <%= sensor.moisture_threshold %>%
        </p>
      <% elsif !has_data %>
        <p class="text-[9px] font-bold text-pulse-moss/30 mt-2 uppercase tracking-widest text-center px-1">
          Branchez votre bridge Python
        </p>
      <% end %>
    </div>

    <!-- Informations Botaniques -->
    <div class="pt-4 border-t border-pulse-mist/50 flex flex-col gap-1">
      <p class="text-xs font-bold text-pulse-forest italic font-merriweather opacity-80">
        <%= plant.display_name %>
      </p>
      <p class="text-[9px] text-pulse-moss/40 font-medium uppercase tracking-[0.15em] font-palanquin">
        <%= plant.scientific_name %>
      </p>
    </div>

    <!-- Horodatage -->
    <div class="mt-4 flex justify-center">
      <span class="inline-flex items-center px-4 py-1.5 bg-pulse-mist/30 rounded-full text-[9px] font-bold text-pulse-moss/40 uppercase tracking-tighter font-palanquin">
        <% if sensor.last_seen_at.present? %>
          Synchro il y a <%= time_ago_in_words(sensor.last_seen_at) %>
        <% else %>
          <%= icon "signal", class: "w-3 h-3 mr-1.5 opacity-40" %> En attente de signal
        <% end %>
      </span>
    </div>
  </div>
</div>
