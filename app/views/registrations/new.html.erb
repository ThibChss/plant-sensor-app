<div class="flex min-h-full flex-col justify-center px-6 py-12 bg-pulse-mist">

  <%# Logo et Titre %>
  <div class="sm:mx-auto sm:w-full sm:max-w-sm flex flex-col items-center">
    <h2 class="mt-10 text-center text-3xl font-black leading-9 tracking-tight text-pulse-forest font-alegreya uppercase tracking-[0.2em]">
      <%= t('.title') %>
    </h2>
    <p class="mt-2 text-center text-sm text-pulse-moss font-merriweather italic">
      <%= t('.subtitle') %>
    </p>
  </div>

  <div class="mt-10 sm:mx-auto sm:w-full sm:max-w-sm">

    <%# Formulaire d'Inscription %>
    <%= form_with url: registrations_path, class: "space-y-5" do |form| %>

      <%# Prénom & Nom (Grille 2 colonnes) %>
      <div class="grid grid-cols-2 gap-4">
        <div>
          <%= form.label :first_name, t('.first_name_label'),
            class: "block text-[10px] font-bold text-pulse-moss uppercase tracking-widest mb-2 px-1 font-alegreya" %>
          <%= form.text_field :first_name, required: true, autofocus: true, placeholder: t('.first_name_placeholder'),
            class: "block w-full rounded-[1.5rem] border-0 py-4 text-pulse-forest shadow-sm ring-1 ring-inset ring-pulse-sage/30 placeholder:text-pulse-sage/60 focus:ring-2 focus:ring-inset focus:ring-pulse-forest bg-white/50 backdrop-blur-sm sm:text-sm px-5 transition-all font-palanquin" %>
        </div>
        <div>
          <%= form.label :last_name, t('.last_name_label'),
            class: "block text-[10px] font-bold text-pulse-moss uppercase tracking-widest mb-2 px-1 font-alegreya" %>
          <%= form.text_field :last_name, required: true, placeholder: t('.last_name_placeholder'),
            class: "block w-full rounded-[1.5rem] border-0 py-4 text-pulse-forest shadow-sm ring-1 ring-inset ring-pulse-sage/30 placeholder:text-pulse-sage/60 focus:ring-2 focus:ring-inset focus:ring-pulse-forest bg-white/50 backdrop-blur-sm sm:text-sm px-5 transition-all font-palanquin" %>
        </div>
      </div>

      <%# Champ Email %>
      <div>
        <%= form.label :email_address, t('.email_label'),
          class: "block text-[10px] font-bold text-pulse-moss uppercase tracking-widest mb-2 px-1 font-alegreya" %>
        <%= form.email_field :email_address, required: true, autocomplete: "email",
          placeholder: t('.email_placeholder'),
          class: "block w-full rounded-[1.5rem] border-0 py-4 text-pulse-forest shadow-sm ring-1 ring-inset ring-pulse-sage/30 placeholder:text-pulse-sage/60 focus:ring-2 focus:ring-inset focus:ring-pulse-forest bg-white/50 backdrop-blur-sm sm:text-sm px-5 transition-all font-palanquin" %>
      </div>

      <%# Champ Mot de passe %>
      <div>
        <%= form.label :password, t('.password_label'),
          class: "block text-[10px] font-bold text-pulse-moss uppercase tracking-widest mb-2 px-1 font-alegreya" %>
        <%= render "shared/password_visibility_field",
            form: form,
            field: :password,
            options: {
              required: true,
              autocomplete: "new-password",
              placeholder: "••••••••",
              class: "block w-full rounded-[1.5rem] border-0 py-4 text-pulse-forest shadow-sm ring-1 ring-inset ring-pulse-sage/30 placeholder:text-pulse-sage/60 focus:ring-2 focus:ring-inset focus:ring-pulse-forest bg-white/50 backdrop-blur-sm sm:text-sm px-5 transition-all font-palanquin"
            } %>
      </div>

      <%# Confirmation Mot de passe %>
      <div>
        <%= form.label :password_confirmation, t('.password_confirmation_label'),
          class: "block text-[10px] font-bold text-pulse-moss uppercase tracking-widest mb-2 px-1 font-alegreya" %>
        <%= render "shared/password_visibility_field",
            form: form,
            field: :password_confirmation,
            options: {
              required: true,
              autocomplete: "new-password",
              placeholder: "••••••••",
              class: "block w-full rounded-[1.5rem] border-0 py-4 text-pulse-forest shadow-sm ring-1 ring-inset ring-pulse-sage/30 placeholder:text-pulse-sage/60 focus:ring-2 focus:ring-inset focus:ring-pulse-forest bg-white/50 backdrop-blur-sm sm:text-sm px-5 transition-all font-palanquin"
            } %>
      </div>

      <%# Bouton Submit %>
      <div class="pt-4">
        <%= form.submit t('.submit'),
          class: "flex w-full justify-center rounded-full bg-pulse-forest px-3 py-4 text-sm font-black leading-6 text-white shadow-lg shadow-pulse-forest/20 hover:shadow-xl hover:scale-[1.02] active:scale-95 transition-all cursor-pointer font-alegreya uppercase tracking-widest" %>
      </div>
    <% end %>

    <%# Lien de retour %>
    <p class="mt-10 text-center text-sm text-pulse-moss font-palanquin">
      <%= t('.sign_in_prompt') %>
      <%= link_to t('.sign_in_link'), new_session_path, class: "font-bold text-pulse-forest hover:underline decoration-2 underline-offset-4" %>
    </p>

  </div>
</div>
