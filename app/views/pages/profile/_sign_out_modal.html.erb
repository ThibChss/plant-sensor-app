<el-dialog>
  <%# On utilise absolute pour rester dans le frame du téléphone %>
  <dialog id="sign-out-dialog" aria-labelledby="sign-out-dialog-title" class="absolute inset-0 z-50 size-auto max-h-none max-w-none overflow-y-auto bg-transparent backdrop:bg-transparent shadow-none border-none outline-none">

  <%# Backdrop : On garde le flou léger de 2px %>
  <el-dialog-backdrop class="absolute inset-0 bg-pulse-forest/20 backdrop-blur-[2px] transition-opacity data-closed:opacity-0 data-enter:duration-300 data-enter:ease-out data-leave:duration-200 data-leave:ease-in"></el-dialog-backdrop>

  <div tabindex="0" class="flex min-h-full items-center justify-center p-8 text-center focus:outline-none">
    <%# Panel avec les arrondis signature [2.5rem] %>
    <el-dialog-panel class="relative mx-auto w-full max-w-[19rem] transform overflow-hidden rounded-[2.5rem] border border-white bg-white/95 text-left shadow-2xl shadow-pulse-forest/10 outline-none backdrop-blur-xl transition-all data-closed:translate-y-4 data-closed:opacity-0 data-enter:duration-300 data-enter:ease-out data-leave:duration-200 data-leave:ease-in data-closed:sm:scale-95">

      <div class="px-6 pt-10 pb-4">
        <%# Header : Icône de déconnexion en Rouge/Rose %>
        <div class="flex flex-col items-center text-center mb-8">
          <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-rose-50 text-rose-500 mb-6">
            <%= icon 'log-out', class: 'w-6 h-6' %>
          </div>
          <h3 id="sign-out-dialog-title" class="text-xl font-black leading-tight text-pulse-forest font-alegreya tracking-tight px-4">
            <%= t('pages.profile.sign_out_modal_title') %>
          </h3>
          <p class="mt-3 text-[10px] leading-relaxed text-pulse-moss/50 font-palanquin uppercase tracking-wider px-2">
            <%= t('pages.profile.sign_out_modal_hint') %>
          </p>
        </div>
      </div>

      <%# Actions : Bouton de déconnexion en rouge et annulation discrète %>
      <div class="flex flex-col items-center gap-4 px-6 pb-10 pt-2">
        <%= button_to session_path,
            method: :delete,
            form: { class: 'w-full contents' },
            class: 'flex w-full justify-center rounded-2xl bg-rose-500 py-4 text-xs font-black uppercase tracking-[0.2em] text-white shadow-lg shadow-rose-500/20 transition-all active:scale-95 font-alegreya' do %>
          <%= t('pages.profile.sign_out_modal_confirm') %>
        <% end %>

        <button
          type="button"
          command="close"
          commandfor="sign-out-dialog"
          class="text-[10px] font-bold text-pulse-moss/40 hover:text-pulse-forest transition-colors font-palanquin uppercase tracking-[0.15em]"
        >
          <%= t('pages.profile.sign_out_modal_cancel') %>
        </button>
      </div>

    </el-dialog-panel>
  </div>


  </dialog>
  </el-dialog>
