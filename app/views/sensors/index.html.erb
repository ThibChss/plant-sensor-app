<div class="relative h-full flex flex-col bg-pulse-mist overflow-hidden">

  <%# Canal Turbo Stream pour recevoir les mises à jour du service ProcessMeasurement %>
  <%= turbo_stream_from Current.user, :sensors %>

  <header class="pt-14 px-6 pb-6 flex justify-between items-center">
    <div class="flex flex-col">
        <span class="text-pulse-forest text-[9px] font-bold uppercase tracking-[0.2em] font-merriweather italic"><%= t('.collection_kicker') %></span>
        <h1 class="text-3xl font-black text-pulse-forest tracking-tight font-alegreya"><%= t('.dashboard_title') %></h1>
    </div>
    <div class="w-12 h-12 bg-white rounded-2xl shadow-sm flex items-center justify-center overflow-hidden border-2 border-white">
       <% if Current.user.first_name.present? %>
         <span class="text-sm font-black text-pulse-forest"><%= Current.user.first_name[0] %></span>
       <% else %>
         <%= icon "user", class: "w-6 h-6 text-pulse-sage" %>
       <% end %>
    </div>
  </header>

  <main class="flex-1 overflow-y-auto px-6 pb-10 no-scrollbar">
    <section>
      <div class="flex justify-between items-center mb-5 px-2">
        <h3 class="text-[10px] font-bold text-pulse-moss uppercase tracking-widest"><%= t('.all_sensors_heading') %></h3>
        <span class="text-[10px] font-bold text-pulse-sage"><%= t('.active_count', count: @sensors.size) %></span>
      </div>

      <div id="sensors_list" class="space-y-4">
        <% if @sensors.any? %>
          <% @sensors.each do |sensor| %>
            <%= render "sensors/sensor_card", sensor: sensor %>
          <% end %>
        <% else %>
          <div class="bg-white/40 border border-dashed border-pulse-sage rounded-[2.5rem] p-10 text-center">
            <p class="text-sm text-pulse-moss italic mb-6"><%= t('.empty_state') %></p>
            <%= link_to t('.add_sensor'), new_sensors_setup_path, class: "inline-block px-8 py-4 bg-pulse-forest text-white rounded-full font-bold text-xs uppercase tracking-widest" %>
          </div>
        <% end %>
      </div>
    </section>
  </main>

  <%# Barre de navigation avec le bouton "+" central %>
  <%= render Components::NavigationBar.new %>
</div>
